# gpt_signup_hybrid — Docker env template.
# Copy → .env, set giá trị thật. .env KHÔNG được commit / KHÔNG bake vào image
# (đã loại trong .dockerignore). Compose inject file này vào container env.

# === Web auth (BẮT BUỘC) ===================================================
# Web bind 0.0.0.0 trong container → token bắt buộc. Compose fail-fast nếu thiếu.
# Sinh chuỗi mạnh: openssl rand -hex 32
GPT_SIGNUP_WEB_TOKEN=change-me-strong-random

# === iCloud HME web API (TÙY CHỌN) =========================================
# Chỉ cần nếu dùng iCloud HME controls trên web UI (/api/icloud/run/*).
# CLI `icloud_hme generate` loop KHÔNG cần token này. Bỏ trống nếu không dùng.
ICLOUD_API_AUTH_TOKEN=

# === Browser / runtime =====================================================
BROWSER_ENGINE=camoufox
RUNTIME_DIR=runtime
HYBRID_MAX_CONCURRENT=2
HYBRID_JOB_TIMEOUT=240

# Giây giữa 2 cycle của HmeRunner (profile hme), min 10.
ICLOUD_RETRY_INTERVAL=900

# BROWSER_HEADLESS để mặc định: web jobs tự set headless=True; toggle headed
# trong UI (Xvfb sẵn sàng cho headed). Không cần set ở đây.
