# Env file cho upi-qr-bot — copy → /etc/upi-qr-bot.env, fill values, chmod 600
# Mỗi dòng = 1 env var; procd auto-export.

TELEGRAM_TOKEN=123456:REPLACE_ME_WITH_BOTFATHER_TOKEN
ALLOWED_USERS=
MAX_CONCURRENT=5
QUEUE_CAPACITY=50
APPROVE_RETRIES=200
RESTART_THRESHOLD=20
MAX_RESTARTS=3
PROXY_POOL=
PROXY_FROM_STEP=3
USER_COOLDOWN_SECONDS=10
USER_MSG_RATE_PER_MIN=20
JOB_TIMEOUT_SECONDS=1800
DB_PATH=/overlay/upi-bot/state.db
QR_OUT_DIR=/tmp/upi-qr
BUNDLES_CACHE_DIR=/tmp/upi-bot-bundles
HTTP_TIMEOUT=30
RUST_LOG=info
